# Copy to .env.local for local development. Never commit real secrets.

# Optional private demo gate. When set, pages and API routes require login.
DEMO_ACCESS_PASSWORD=

# Q&A providers. OPENAI_API_KEY is preferred; GEMINI_API_KEY is fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
USE_MOCK_AI=false

# OpenAI TTS.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_EN=onyx
OPENAI_TTS_VOICE_AR=cedar

# D-ID streaming avatar.
DID_API_KEY=
DID_PRESENTER_URL=
DID_VOICE_ID=
DID_VOICE_ID_AR=
